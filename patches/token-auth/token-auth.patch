+import { APIError, createAuthEndpoint } from 'better-auth/api';
+import { setSessionCookie } from 'better-auth/cookies';
+import debug from 'debug';
+import { z } from 'zod';
+
+import { authorizeToken } from '@/libs/better-auth/sso/providers/token';
+
+const log = debug('middleware:auth:token-auth');
+
+/**
+ * Token-based authentication plugin.
+ *
+ * Exposes `POST /token/sign-in` (server-side `auth.api.tokenSignIn`) which:
+ *  1. Validates the user-supplied token against the configured upstream.
+ *  2. Looks up the user by email — or creates one with `emailVerified=true`
+ *     (no password required, since trust is delegated to the upstream).
+ *  3. Issues a better-auth session and attaches the session cookies to
+ *     the response.
+ *
+ * Kept intentionally small so it can be invoked either via HTTP from an
+ * untrusted client (if enabled in the token provider) or programmatically
+ * from a trusted Next.js API route via `auth.api.tokenSignIn({ body })`.
+ */
+export const tokenAuth = () => ({
+  id: 'token-auth',
+  endpoints: {
+    tokenSignIn: createAuthEndpoint(
+      '/token/sign-in',
+      {
+        method: 'POST',
+        body: z.object({
+          token: z.string().min(1),
+        }),
+        requireHeaders: true,
+        metadata: {
+          openapi: {
+            description: 'Sign in / sign up with a delegated token',
+            operationId: 'tokenSignIn',
+            responses: {
+              200: {
+                description: 'Authenticated',
+                content: {
+                  'application/json': {
+                    schema: {
+                      properties: {
+                        token: { type: 'string' },
+                        user: {
+                          properties: {
+                            createdAt: { type: 'string' },
+                            email: { type: 'string' },
+                            emailVerified: { type: 'boolean' },
+                            id: { type: 'string' },
+                            image: { type: 'string', nullable: true },
+                            name: { type: 'string' },
+                            updatedAt: { type: 'string' },
+                          },
+                          type: 'object',
+                        },
+                      },
+                      type: 'object',
+                    },
+                  },
+                },
+              },
+            },
+            summary: 'Sign in / sign up with a delegated token',
+          },
+        },
+      },
+      async (ctx) => {
+        const userInfo = await authorizeToken({ token: ctx.body.token });
+        if (!userInfo) {
+          log('Token validation failed');
+          throw new APIError('UNAUTHORIZED', { message: 'INVALID_TOKEN' });
+        }
+
+        log('User info retrieved: %s', userInfo);
+
+        const email = String(userInfo.email).toLowerCase().trim();
+        let user: any = await ctx.context.internalAdapter.findUserByEmail(email);
+        // Some adapters return `{ user, accounts }` shape; normalize.
+        if (user && (user as any).user) user = (user as any).user;
+
+        if (!user) {
+          log('User does not exist, creating new user...', { email });
+          user = await ctx.context.internalAdapter.createUser({
+            email,
+            emailVerified: true,
+            name: userInfo.name || email,
+          });
+          if (!user) {
+            throw new APIError('INTERNAL_SERVER_ERROR', {
+              message: 'FAILED_TO_CREATE_USER',
+            });
+          }
+        }
+
+        const session: any = await ctx.context.internalAdapter.createSession(user.id);
+        if (!session) {
+          throw new APIError('INTERNAL_SERVER_ERROR', {
+            message: 'FAILED_TO_CREATE_SESSION',
+          });
+        }
+
+        await setSessionCookie(ctx as any, { session, user });
+
+        return ctx.json({
+          token: session.token,
+          user: {
+            createdAt: (user as any).createdAt,
+            email: (user as any).email,
+            emailVerified: (user as any).emailVerified,
+            id: (user as any).id,
+            image: (user as any).image,
+            name: (user as any).name,
+            updatedAt: (user as any).updatedAt,
+          },
+        });
+      },
+    ),
+  },
+});
+
+export type TokenAuthPlugin = ReturnType<typeof tokenAuth>;
