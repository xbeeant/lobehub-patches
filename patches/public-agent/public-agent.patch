+CREATE TABLE IF NOT EXISTS "public_agents" (
+  "id" text COLLATE "pg_catalog"."default" NOT NULL,
+  "slug" varchar(100) COLLATE "pg_catalog"."default",
+  "title" varchar(255) COLLATE "pg_catalog"."default",
+  "description" varchar(1000) COLLATE "pg_catalog"."default",
+  "tags" jsonb DEFAULT '[]'::jsonb,
+  "avatar" text COLLATE "pg_catalog"."default",
+  "background_color" text COLLATE "pg_catalog"."default",
+  "plugins" jsonb,
+  "chat_config" jsonb,
+  "few_shots" jsonb,
+  "model" text COLLATE "pg_catalog"."default",
+  "params" jsonb DEFAULT '{}'::jsonb,
+  "provider" text COLLATE "pg_catalog"."default",
+  "system_role" text COLLATE "pg_catalog"."default",
+  "tts" jsonb,
+  "opening_message" text COLLATE "pg_catalog"."default",
+  "opening_questions" text[] COLLATE "pg_catalog"."default" DEFAULT '{}'::text[],
+  "virtual" bool DEFAULT false,
+  "market_identifier" text COLLATE "pg_catalog"."default",
+  "editor_data" jsonb,
+  "agency_config" jsonb,
+  "mcp_config" jsonb,
+  "mcp_tools_config" jsonb,
+  "skills_config" jsonb,
+  "version" varchar(50) DEFAULT '1.0.0',
+  "is_active" boolean DEFAULT true,
+  "created_at" timestamp DEFAULT now() NOT NULL,
+  "updated_at" timestamp DEFAULT now() NOT NULL,
+  "accessed_at" timestamp DEFAULT now() NOT NULL
+);
+
+CREATE UNIQUE INDEX IF NOT EXISTS "public_agents_slug_unique" ON "public_agents" USING btree ("slug");
+CREATE INDEX IF NOT EXISTS "public_agents_title_idx" ON "public_agents" USING btree ("title");
+CREATE INDEX IF NOT EXISTS "public_agents_is_active_idx" ON "public_agents" USING btree ("is_active");
+
+ALTER TABLE "agents" ADD COLUMN IF NOT EXISTS "public_agent_id" text;
+ALTER TABLE "agents" ADD COLUMN IF NOT EXISTS "synced_version" varchar(50);
+ALTER TABLE "agents" ADD CONSTRAINT "agents_public_agent_id_fkey" FOREIGN KEY ("public_agent_id") REFERENCES "public_agents"("id") ON DELETE SET NULL;
+CREATE INDEX IF NOT EXISTS "agents_public_agent_id_idx" ON "agents" USING btree ("public_agent_id");
+CREATE INDEX IF NOT EXISTS "agents_synced_version_idx" ON "agents" USING btree ("synced_version");
