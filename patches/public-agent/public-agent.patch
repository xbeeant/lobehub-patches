@@ -0,0 +1,66 @@
+import { eq, inArray } from 'drizzle-orm';
+
+import { publicAgents } from '../schemas';
+import type { NewPublicAgent, PublicAgentItem } from '../schemas/publicAgent';
+import type { LobeChatDatabase } from '../type';
+
+export class PublicAgentModel {
+  private db: LobeChatDatabase;
+
+  constructor(db: LobeChatDatabase) {
+    this.db = db;
+  }
+
+  getAll = async (options?: { isActive?: boolean }): Promise<PublicAgentItem[]> => {
+    const where = options?.isActive !== undefined ? eq(publicAgents.isActive, options.isActive) : undefined;
+
+    return this.db.query.publicAgents.findMany({
+      orderBy: (publicAgents, { desc }) => [desc(publicAgents.createdAt)],
+      where,
+    });
+  };
+
+  getById = async (id: string): Promise<PublicAgentItem | null> => {
+    return this.db.query.publicAgents.findFirst({
+      where: eq(publicAgents.id, id),
+    });
+  };
+
+  getBySlug = async (slug: string): Promise<PublicAgentItem | null> => {
+    return this.db.query.publicAgents.findFirst({
+      where: eq(publicAgents.slug, slug),
+    });
+  };
+
+  create = async (config: NewPublicAgent): Promise<PublicAgentItem> => {
+    const [result] = await this.db.insert(publicAgents).values([config]).returning();
+    return result;
+  };
+
+  batchCreate = async (configs: NewPublicAgent[]): Promise<PublicAgentItem[]> => {
+    if (configs.length === 0) return [];
+    return this.db.insert(publicAgents).values(configs).returning();
+  };
+
+  update = async (id: string, data: Partial<PublicAgentItem>): Promise<PublicAgentItem | null> => {
+    const [result] = await this.db
+      .update(publicAgents)
+      .set({ ...data, updatedAt: new Date() })
+      .where(eq(publicAgents.id, id))
+      .returning();
+    return result ?? null;
+  };
+
+  delete = async (id: string): Promise<void> => {
+    await this.db.delete(publicAgents).where(eq(publicAgents.id, id));
+  };
+
+  batchDelete = async (ids: string[]): Promise<void> => {
+    if (ids.length === 0) return;
+    await this.db.delete(publicAgents).where(inArray(publicAgents.id, ids));
+  };
+
+  toggleActive = async (id: string, isActive: boolean): Promise<PublicAgentItem | null> => {
+    return this.update(id, { isActive });
+  };
+}
