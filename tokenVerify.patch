diff --git a/src/services/tokenAuth/index.ts b/src/services/tokenAuth/index.ts
new file mode 100644
index 000000000..1b17d121d
--- /dev/null
+++ b/src/services/tokenAuth/index.ts
@@ -0,0 +1,423 @@
+import type { LobeChatDatabase } from '@lobechat/database';
+import { createNanoId, idGenerator } from '@lobechat/database';
+import { session as betterAuthSession, users } from '@lobechat/database/schemas';
+import debug from 'debug';
+import { eq } from 'drizzle-orm';
+
+import { authEnv } from '@/envs/auth';
+import { getRedisConfig } from '@/envs/redis';
+import { initializeRedis, isRedisEnabled } from '@/libs/redis';
+import { UserService } from '@/server/services/user';
+
+const log = debug('middleware:token-auth');
+
+/**
+ * Get nested value from object using dot-separated key path.
+ * Similar to lodash.get, supports keys like 'data.user.email'.
+ *
+ * @param obj - The object to get value from
+ * @param path - Dot-separated key path (e.g., 'data.user.email')
+ * @returns The value at the path, or undefined if not found
+ */
+const getNestedValue = (obj: Record<string, unknown>, path: string): unknown => {
+  if (!path) return undefined;
+
+  const keys = path.split('.');
+  let current: unknown = obj;
+
+  for (const key of keys) {
+    if (current === null || current === undefined) {
+      return undefined;
+    }
+
+    if (typeof current !== 'object') {
+      return undefined;
+    }
+
+    current = (current as Record<string, unknown>)[key];
+  }
+
+  return current;
+};
+
+/**
+ * User info returned from the token verification API
+ */
+interface TokenVerifyUserInfo {
+  email: string;
+  id: string;
+  name: string;
+}
+
+/**
+ * Result of token authentication
+ */
+interface TokenAuthResult {
+  sessionToken: string;
+  userId: string;
+}
+
+/**
+ * TokenAuthService handles token-based authentication from cookie tokens.
+ *
+ * When a user is not logged in but has a token cookie, this service:
+ * 1. Calls the configured verification URL to validate the token
+ * 2. Creates a local user if the user doesn't exist
+ * 3. Creates a Better Auth session for the user
+ */
+export class TokenAuthService {
+  private db: LobeChatDatabase;
+
+  constructor(db: LobeChatDatabase) {
+    this.db = db;
+  }
+
+  /**
+   * Check if token authentication is enabled
+   */
+  static isTokenAuthEnabled(): boolean {
+    return !!authEnv.AUTH_TOKEN_VERIFY_URL;
+  }
+
+  /**
+   * Get the configured token cookie key
+   */
+  static getTokenCookieKey(): string {
+    return authEnv.AUTH_TOKEN_COOKIE_KEY || 'token';
+  }
+
+  /**
+   * Extract token from cookie header
+   */
+  static extractTokenFromCookie(cookieHeader: string | null): string | null {
+    if (!cookieHeader) return null;
+
+    const tokenKey = TokenAuthService.getTokenCookieKey();
+    const cookies = cookieHeader.split(';').map((c) => c.trim());
+
+    for (const cookie of cookies) {
+      const [key, value] = cookie.split('=');
+      if (key === tokenKey && value) {
+        return value.trim();
+      }
+    }
+
+    return null;
+  }
+
+  /**
+   * Extract user info from API response using configured key paths
+   */
+  private extractUserInfoFromResponse(
+    responseData: Record<string, unknown>,
+  ): TokenVerifyUserInfo | null {
+    const idKey = authEnv.AUTH_TOKEN_USER_INFO_ID_KEY || 'id';
+    const emailKey = authEnv.AUTH_TOKEN_USER_INFO_EMAIL_KEY || 'email';
+    const nameKey = authEnv.AUTH_TOKEN_USER_INFO_NAME_KEY || 'name';
+
+    const id = getNestedValue(responseData, idKey);
+    const email = getNestedValue(responseData, emailKey);
+    const name = getNestedValue(responseData, nameKey);
+
+    log('Extracted user info: id=%s, email=%s, name=%s', id, email, name);
+
+    // Convert to string types
+    const idStr = typeof id === 'string' ? id : undefined;
+    const emailStr = typeof email === 'string' ? email : undefined;
+    const nameStr = typeof name === 'string' ? name : undefined;
+
+    // If we don't have at least id or name, we can't create a user
+    if (!idStr && !nameStr) {
+      log('User info missing both id and name');
+      return null;
+    }
+
+    // Generate email if not provided
+    let finalEmail = emailStr;
+    if (!finalEmail && nameStr) {
+      const defaultDomain = authEnv.AUTH_TOKEN_DEFAULT_EMAIL_DOMAIN || 'lobehub.com';
+      // Generate email from name: convert to lowercase and replace spaces with dots
+      const emailPrefix = nameStr.toLowerCase().replaceAll(/\s/g, '.');
+      finalEmail = `${emailPrefix}@${defaultDomain}`;
+      log('Generated email from name: %s', finalEmail);
+    }
+
+    return {
+      email: finalEmail || '',
+      id: idStr || '',
+      name: nameStr || '',
+    };
+  }
+
+  /**
+   * Verify token with the external API
+   */
+  private async verifyTokenWithExternalApi(token: string): Promise<TokenVerifyUserInfo | null> {
+    const verifyUrl = authEnv.AUTH_TOKEN_VERIFY_URL;
+    if (!verifyUrl) {
+      log('Token verification URL not configured');
+      return null;
+    }
+
+    try {
+      log('Verifying token with external API: %s', verifyUrl);
+      const tokenKey = TokenAuthService.getTokenCookieKey();
+
+      // Add timeout to prevent hanging
+      const controller = new AbortController();
+      const timeoutId = setTimeout(() => {
+        controller.abort();
+      }, 10000); // 10 seconds timeout
+
+      const response = await fetch(verifyUrl, {
+        headers: {
+          Cookie: `${tokenKey}=${token}`,
+        },
+        signal: controller.signal,
+      });
+
+      clearTimeout(timeoutId);
+
+      if (!response.ok) {
+        log('Token verification failed with status: %d', response.status);
+        return null;
+      }
+
+      const responseData = (await response.json()) as Record<string, unknown>;
+      log('Token verification response: %O', responseData);
+
+      return this.extractUserInfoFromResponse(responseData);
+    } catch (error) {
+      // Handle different types of errors
+      if (error instanceof Error) {
+        if (error.name === 'AbortError') {
+          log('Token verification timed out');
+        } else if (error.cause && typeof error.cause === 'object' && 'code' in error.cause) {
+          const code = (error.cause as Record<string, unknown>).code;
+          if (code === 'ECONNREFUSED') {
+            log('Token verification failed: Connection refused to %s', verifyUrl);
+          } else {
+            log('Token verification network error: %s - %s', code, error.message);
+          }
+        } else {
+          log('Token verification error: %s', error.message);
+        }
+      } else {
+        log('Token verification error: %O', error);
+      }
+      return null;
+    }
+  }
+
+  /**
+   * Find or create user based on external API user info
+   */
+  private async findOrCreateUser(userInfo: TokenVerifyUserInfo): Promise<string> {
+    // Try to find user by email first
+    if (userInfo.email) {
+      try {
+        const existingUser = await this.db.query.users.findFirst({
+          where: eq(users.email, userInfo.email),
+        });
+
+        if (existingUser) {
+          log('Found existing user by email: %s', existingUser.id);
+          return existingUser.id;
+        }
+      } catch (error) {
+        log('Error querying user by email: %O', error);
+        // If table doesn't exist or other error, continue to create user
+      }
+    }
+
+    // Create new user
+    const userId = userInfo.id || idGenerator('user', 32 - 'user_'.length);
+    const now = new Date();
+
+    log('Creating new user: %s', userId);
+
+    try {
+      const [newUser] = await this.db
+        .insert(users)
+        .values({
+          id: userId,
+          email: userInfo.email || null,
+          fullName: userInfo.name || null,
+          emailVerified: true, // Token from external API is considered verified
+          createdAt: now,
+          updatedAt: now,
+          lastActiveAt: now,
+        })
+        .returning();
+
+      // Initialize user settings and business features
+      const userService = new UserService(this.db);
+      await userService.initUser({
+        email: newUser.email,
+        id: newUser.id,
+        username: null,
+        createdAt: newUser.createdAt,
+      });
+
+      return newUser.id;
+    } catch (error) {
+      log('Error creating user: %O', error);
+      throw error;
+    }
+  }
+
+  /**
+   * Get the user data for session caching
+   *
+   * Better Auth expects the user object to have specific fields:
+   * - id: string
+   * - email: string | null
+   * - name: string | null (mapped from fullName in database)
+   * - emailVerified: boolean | null
+   * - image: string | null (mapped from avatar in database)
+   * - createdAt: string (ISO format)
+   * - updatedAt: string (ISO format)
+   */
+  private async getUserForSession(userId: string): Promise<Record<string, unknown> | null> {
+    try {
+      const user = await this.db.query.users.findFirst({
+        where: eq(users.id, userId),
+      });
+
+      if (!user) {
+        log('User not found for session: %s', userId);
+        return null;
+      }
+
+      // Better Auth expects 'name' not 'fullName' based on the config:
+      // user: { fields: { name: 'fullName' } }
+      return {
+        id: user.id,
+        email: user.email || null,
+        name: user.fullName || null,
+        emailVerified: user.emailVerified,
+        image: (user as Record<string, unknown>).avatar || null,
+        createdAt: user.createdAt.toISOString(),
+        updatedAt: user.updatedAt.toISOString(),
+      };
+    } catch (error) {
+      log('Error fetching user for session: %O', error);
+      return null;
+    }
+  }
+
+  /**
+   * Update Redis cache with session data
+   *
+   * Note: The key format must match what Better Auth expects.
+   * Better Auth's secondaryStorage adds 'better-auth:' prefix automatically,
+   * so we only need to provide the key suffix 'session:${sessionToken}'.
+   */
+  private async updateSessionCache(
+    sessionToken: string,
+    sessionData: Record<string, unknown>,
+    ttlSeconds: number,
+  ): Promise<void> {
+    const redisConfig = getRedisConfig();
+    if (!isRedisEnabled(redisConfig)) {
+      log('Redis is not enabled, skipping session cache update');
+      return;
+    }
+
+    try {
+      const redisClient = await initializeRedis(redisConfig);
+      if (!redisClient) {
+        log('Failed to initialize Redis client');
+        return;
+      }
+
+      // Better Auth's secondaryStorage adds 'better-auth:' prefix,
+      // so we use 'session:${sessionToken}' as the key suffix
+      const cacheKey = `session:${sessionToken}`;
+      await redisClient.setex(cacheKey, ttlSeconds, JSON.stringify(sessionData));
+      log('Session cache updated for key: %s', cacheKey);
+    } catch (error) {
+      log('Error updating session cache: %O', error);
+    }
+  }
+
+  /**
+   * Authenticate with token and create a Better Auth session
+   *
+   * @param token - The token from cookie
+   * @param ipAddress - Client IP address
+   * @param userAgent - Client user agent
+   * @returns TokenAuthResult with sessionToken and userId, or null if authentication failed
+   */
+  async authenticateWithToken(
+    token: string,
+    ipAddress?: string,
+    userAgent?: string,
+  ): Promise<TokenAuthResult | null> {
+    log('Starting token authentication process');
+
+    // Step 1: Verify token with external API
+    const userInfo = await this.verifyTokenWithExternalApi(token);
+    if (!userInfo) {
+      log('Token verification failed or returned no user info');
+      return null;
+    }
+
+    log('Token verified successfully for user: %s', userInfo.email || userInfo.name);
+
+    // Step 2: Find or create user
+    const userId = await this.findOrCreateUser(userInfo);
+    log('User identified/created with ID: %s', userId);
+
+    // Step 3: Get user data for session
+    const userData = await this.getUserForSession(userId);
+    if (!userData) {
+      log('Failed to get user data for session');
+      return null;
+    }
+
+    // Step 4: Create session in database
+    const sessionToken = createNanoId(32)();
+    const sessionId = createNanoId(32)();
+    const expiresAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000); // 7 days
+
+    try {
+      await this.db.insert(betterAuthSession).values({
+        id: sessionId,
+        token: sessionToken,
+        userId,
+        expiresAt,
+        ipAddress: ipAddress || null,
+        userAgent: userAgent || null,
+      });
+
+      log('Session created in database for user: %s', userId);
+    } catch (error) {
+      log('Error creating session in database: %O', error);
+      throw error;
+    }
+
+    // Step 5: Update Redis cache
+    const sessionTtlSeconds = 7 * 24 * 60 * 60; // 7 days in seconds
+    const sessionCacheData = {
+      user: userData,
+      session: {
+        id: sessionToken,
+        userId,
+        expiresAt: expiresAt.toISOString(),
+        token: sessionToken,
+      },
+    };
+
+    await this.updateSessionCache(
+      sessionToken,
+      sessionCacheData as Record<string, unknown>,
+      sessionTtlSeconds,
+    );
+
+    return {
+      sessionToken,
+      userId,
+    };
+  }
+}
