new file mode 100644
index 0000000000..4e0202def6
--- /dev/null
+++ b/src/libs/better-auth/sso/providers/token.ts
@@ -0,0 +1,94 @@
+import debug from 'debug';
+import { authEnv } from '@/envs/auth';
+
+const log = debug('middleware:auth:token-provider');
+
+export const tokenCredentials = {
+    id: 'token',
+    name: 'Token Authentication',
+    type: 'credentials' as const,
+
+    credentials: {
+        token: { label: 'Token', type: 'text' },
+    },
+
+    async authorize(credentials: { token?: string }) {
+        const rawToken = credentials.token?.trim();
+
+        if (!rawToken) {
+            log('Token is empty or missing');
+            return null;
+        }
+
+        if (!authEnv.AUTH_TOKEN_AUTH_ENABLED || authEnv.AUTH_TOKEN_AUTH_ENABLED === '0') {
+            log('Provider is disabled via AUTH_TOKEN_AUTH_ENABLED');
+            return null;
+        }
+
+        if (!authEnv.AUTH_TOKEN_AUTH_USER_INFO_URL) {
+            log('AUTH_TOKEN_AUTH_USER_INFO_URL is not configured');
+            return null;
+        }
+
+        try {
+            log('Fetching user info with token (length: %d)', rawToken.length);
+
+            const url = new URL(authEnv.AUTH_TOKEN_AUTH_USER_INFO_URL);
+            url.searchParams.append('token', rawToken);   // Token 作为 GET 参数
+
+            const response = await fetch(url.toString(), {
+                method: 'GET',
+                headers: {
+                    'Content-Type': 'application/json',
+                    Accept: 'application/json',
+                },
+                signal: AbortSignal.timeout(10000), // 10秒超时
+            });
+
+            if (!response.ok) {
+                log('User info API error: %d %s', response.status, response.statusText);
+                return null;
+            }
+
+            const data = await response.json();
+
+            const getPath = (obj: any, path?: string) => {
+                if (!path || !obj) return undefined;
+                return path.split('.').reduce((o, key) => (o?.[key] !== undefined ? o[key] : undefined), obj);
+            };
+
+            let email = getPath(data, authEnv.AUTH_TOKEN_AUTH_EMAIL_PATH);
+            const userId = getPath(data, authEnv.AUTH_TOKEN_AUTH_ID_PATH) || rawToken;
+            const name = getPath(data, authEnv.AUTH_TOKEN_AUTH_NAME_PATH);
+
+            if (!email) {
+                email = `${String(userId)}${authEnv.AUTH_TOKEN_AUTH_EMAIL_SUFFIX || '@lobehub.com'}`;
+            }
+
+            if (!email || !userId) {
+                log('Missing email or userId in API response');
+                return null;
+            }
+
+            const user = {
+                id: String(userId),
+                email: String(email).toLowerCase().trim(),
+                name: String(name || email).trim(),
+            };
+
+            log('User authenticated successfully: %s', user.email);
+            return user;
+
+        } catch (error: any) {
+            if (error.name === 'AbortError') {
+                log('Request timeout');
+            } else {
+                log('Error occurred: %s', error?.message || error);
+            }
+            return null;
+        }
+    },
+};
+
+export { tokenCredentials as default };
+export const authorizeToken = tokenCredentials.authorize;
