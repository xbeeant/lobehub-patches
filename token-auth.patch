index 0000000000..87ffecbde3
--- /dev/null
+++ b/src/app/(backend)/api/auth/token/route.ts
@@ -0,0 +1,76 @@
+import { NextRequest, NextResponse } from 'next/server';
+import debug from 'debug';
+import { auth } from '@/auth';
+
+const log = debug('middleware:auth:token-route');
+
+/**
+ * Token-based sign-in endpoint.
+ *
+ * Accepts `?token=...` on the query string and delegates to the
+ * `auth.api.tokenSignIn` endpoint (implemented by the `token-auth`
+ * plugin), which:
+ *  1. Validates the token against the configured upstream.
+ *  2. Looks up / creates the local user (no password required).
+ *  3. Issues a better-auth session and sets the session cookies.
+ */
+export async function GET(req: NextRequest) {
+  const token = req.nextUrl.searchParams.get('token');
+
+  if (!token) {
+    log('Missing token parameter');
+    return NextResponse.json(
+      { error: '缺少 token 参数' },
+      { status: 400 },
+    );
+  }
+
+  try {
+    log('Validating token...');
+
+    // `auth.api.<endpoint>` when called programmatically returns the
+    // endpoint's response body directly; to access the Set-Cookie
+    // headers written by `setSessionCookie`, we request the full
+    // { response, headers, status } tuple via returnHeaders=true.
+    const result = (await auth.api.tokenSignIn({
+      body: { token },
+      headers: Object.fromEntries(req.headers.entries()),
+      returnHeaders: true,
+      returnStatus: true,
+    } as any)) as unknown as {
+      response: { token: string; user: { id: string; email: string; name: string } };
+      headers: Headers;
+      status: number;
+    };
+
+    const { response, headers } = result;
+
+    log('Token auth completed successfully for user: %s', response.user.email);
+
+    const res = NextResponse.json(
+      {
+        success: true,
+        user: response.user,
+        session: { token: response.token },
+      },
+      { status: result.status || 200 },
+    );
+
+    // Propagate the Set-Cookie headers (session token, session data,
+    // etc.) emitted by `setSessionCookie` in the token-auth plugin so
+    // the browser receives a standard better-auth session cookie.
+    if (headers && typeof (headers as any).forEach === 'function') {
+      (headers as Headers).forEach((value, key) => {
+        res.headers.append(key, value);
+      });
+    }
+
+    return res;
+  } catch (error: any) {
+    log('Token route error: %s', error?.message || error);
+    return NextResponse.json(
+      { error: error?.message || '服务器内部错误' },
+      { status: 500 },
+    );
+  }
+}
